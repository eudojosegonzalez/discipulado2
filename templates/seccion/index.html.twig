{% extends 'base.html.twig' %}

{% block title %}Secciones - Maranatha Discipulado{% endblock %}
{% block scripts %}
    <script src="assets/js/seccion/new_seccion.js"></script>
    <script>

    </script>
{% endblock %}

{% block body %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <button type="button" id="sidebarCollapse" class="btn btn-dark mr-2">
            <i class="fas fa-bars"></i>
        </button>
        <a class="navbar-brand" href="#">
           <img src="{{ appLogo }}" almiModalAlumnost="Logo" style="height:45px !important">
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>        
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-user-circle mr-1"></i> Perfil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-cog mr-1"></i> Configuración</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/logout"><i class="fas fa-sign-out-alt mr-1"></i> Salir</a>
                </li>
            </ul>
        </div>
    </nav>
    <!-- Sidebar -->
    {% include 'navigation_admin.html.twig' %}
    <!-- Contenido Principal -->
    <div id="content" style=" padding:5px !important">    
        <p>&nbsp;</p>
        <h1>Secciones en el Sistema</h1>
        <p>&nbsp;</p>
        <div class='row'>
            <div class='col-12 col-md-8 col-lg-8 mb-0' style='margin:auto !important'>
                <div class="navigation">
                    {{ knp_pagination_render(seccions) }}
                </div>              
            </div>
            <div class='col-12 col-md-4 col-lg-4 text-left mb-0'>
                <div class="input-group">
                    <input type="text" class="form-control" id='searchInput' name='searchInput' placeholder="Buscar Cedula Nombre o Apellido" aria-label="Buscar" aria-describedby="basic-addon2" value='{{ searchInput  }}'>
                    <div class="input-group-append">
                        <button class="btn btn-primary" type="button" onclick='javascript:search()'>Buscar</button>
                    </div>
                </div>                
            </div>
        </div>        
        <div class="my-3 text-center"> {# Un div para agrupar y dar un poco de margen #}
            <a href="{{ path('app_seccion_new') }}" title='Agregar una sección nueva al sistema' class="btn btn-primary btn-lg rounded-lg">
                <i class="fa fa-plus-square" style='font-size: 24px;'></i> {# Ajusté el tamaño para que se vea mejor en un botón #}
                Agregar Sección
            </a>
        </div>         
        <table class="table table-striped">
            <thead>
                <tr class="text-center bg-dark text-white">
                    <th>Id</th>
                    <th>Nombre</th>
                    <th>Fecha Creación</th>
                    <th>Cohorte</th>
                    <th>Estado</th>
                    <th>Discipulos</th>
                    <th>Secciones</th>
                </tr>
            </thead>
            <tbody>
            {% set i = 1 %}
            {% for seccion in seccions %}
                <tr>
                    <td class="text-center">{{ i }}</td>
                    <td>{{ seccion.nombre }}</td>
                    <td class="text-center">{{ seccion.fechaCreacion ? seccion.fechaCreacion|date('d/m/Y') : '' }}</td>
                    <td class="text-center">{{ seccion.cohorte.nombre }}</td>
                    <td class="text-center">
                        {% if seccion.estado == '1' %}
                            <span class='badge badge-success'>Activo</span>
                        {% else %}
                            <span class='badge badge-danger'>Inactivo</span>
                        {% endif %}                      
                    </td>
                    <td class="text-center">
                        <a href="javascript:verDiscipulos({{ seccion.id }})">{{ seccion.nDiscipulos }}</a>
                    </td>
                    <td class="text-center">
                        <a href="{{ path('app_seccion_show', {'id': seccion.id}) }}"><i class="fa-solid fa-eye"></i></a>
                        <a href="{{ path('app_seccion_edit', {'id': seccion.id}) }}"><i class="fa-solid fa-user-pen"></i></a>
                    </td>
                </tr>
                {% set i = i + 1 %}
            {% else %}
                <tr>
                    <td colspan="6" class="text-danger">No se han definido secciones en el sistema</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- cuadro modal  de anuncios -->
    <!-- cuadro modal  de anuncios -->
    <div class="modal fade" id="miModal" tabindex="-1" role="dialog" aria-labelledby="miModalLabel" aria-hidden="true" style="z-index: 100050;">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="miModalLabel">Título del Modal</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar" onclick="javascript:cierraModal()">
                    <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    Aquí va el contenido de tu modal. Puedes incluir texto, imágenes, formularios, ¡lo que necesites!
                </div>
            </div>
        </div>
    </div>    

    <div class="modal fade" id="miModalAlumnos" tabindex="-2" role="dialog" aria-labelledby="miModalLabel" aria-hidden="true" style="z-index: 10050;">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="miModalLabel">Configuración de la Sección</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar" onclick="javascript:cierraModal()">
                    <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class='row'>
                        <div class='col-12 mb-0 d-flex justify-content-center'>
                            <input type="button" class="btn btn-primary" value="Agregar a Sección" onclick="javascript:agregarASeccion()">
                            <input type="button" class="btn btn-danger" value="Quitar de Sección" onclick="javascript:quitarDeSeccion()">
                            <input type="button" class="btn btn-success" value="Guardar Cambios" onclick="javascript:guardarSeccion()">
                        </div>
                    </div>
                    <div class='row'>
                        <div class='col-12 mb-0 text-center'>
                            <p><span class='badge badge-info'>Método de Ordenamiento</span></p>
                            <p>
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                        <label for='sentidoOrdenamiento'>Sentido </label>
                                    </div>
                                    <select id='sentidoOrdenamiento' class='form-control form-control-sm' style='width:150px !important; display:inline-block !important'>
                                        <option value='1'>Ascendente</option>
                                        <option value='-1'>Descendente</option>
                                    </select>
                                </div>
                            </p>
                            <input type="button" class="btn-outline-info btn-sm" value="Por Edad" onclick="javascript:ordenarPorEdad()">
                            <input type="button" class="btn-outline-info btn-sm" value="Por Nombre" onclick="javascript:ordenarPorNombre()">
                            <input type="button" class="btn-outline-info btn-sm" value="Por Apellido" onclick="javascript:ordenarPorApellido()">
                            <input type="button" class="btn-outline-info btn-sm" value="Por Cédula" onclick="javascript:ordenarPorCedula()">
                        </div>
                    </div>
                    <div class='row'>
                        <div class='col-12 col-md-6 col-lg-6 mb-0' style="padding-right: 2.5px !important; ">
                            <p>Discipulos Sin Sección</p>
                            <table class="table table-striped" style='font-size:9px !important'>
                                <thead>
                                    <tr class="text-center bg-dark text-white">
                                        <th>Cedula</th>
                                        <th>Nombre Completo</th>
                                        <th>Edad</th>
                                    </tr>
                                </thead>
                                <tbody id='tblSinSeccion'>
                                </tbody>
                            </table>
                        </div>
                        <div class='col-12 col-md-6 col-lg-6 mb-0' style="padding-left: 2.5px !important; ">
                            <p>Discipulos en la Sección</p>
                            <table class="table table-striped" style='font-size:9px !important'>
                                <thead>
                                    <tr class="text-center bg-dark text-white">
                                        <th>Cedula</th>
                                        <th>Nombre Completo</th>    
                                        <th>Edad</th>
                                    </tr>
                                </thead>
                                <tbody id='tblConSeccion'>
                                </tbody>
                            </table>
                            <input type="hidden" id='idSeccion' value='0'>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}


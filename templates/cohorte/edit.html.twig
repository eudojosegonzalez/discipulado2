{% extends 'base.html.twig' %}

{% block title %}Cohorte - Maranatha Discipulado{% endblock %}
{% block scripts %}
    <script>
        $(document).ready(function() {
            // Colapsar/Expandir Sidebar
            $('#sidebarCollapse').on('click', function() {
                $('#sidebar').toggleClass('active');
                $('#content').toggleClass('active');
            });
            
            // Hacer que los items del sidebar sean activos al hacer clic
            $('.sidebar-item').on('click', function() {
                $('.sidebar-item').removeClass('active');
                $(this).addClass('active');
            });
        });        
    </script>
{% endblock %}

{% block body %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <button type="button" id="sidebarCollapse" class="btn btn-dark mr-2">
            <i class="fas fa-bars"></i>
        </button>
        <a class="navbar-brand" href="#">
           <img src="../{{ appLogo }}" alt="Logo" style="height:45px !important">
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>        
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-user-circle mr-1"></i> Perfil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-cog mr-1"></i> Configuración</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/logout"><i class="fas fa-sign-out-alt mr-1"></i> Salir</a>
                </li>
            </ul>
        </div>
    </nav>
    <!-- Sidebar -->
    {% include 'navigation_admin.html.twig' %}
    <!-- Contenido Principal -->
    <div id="content" style="padding:5px !important"> 
        <p>&nbsp;</p>   
        <div class='card col-12 col-md-63 col-lg-6 shadow p-3 mb-5 bg-white rounded' style='margin:auto !important'>
            <div class='card-header'>
                <p class='text-center'><a href="{{ path('app_cohorte_index') }}" title='Regresar al listado de Cohortes'><i class="far fa-list-alt" style="font-size:24px"></i></a></p>
                <h3>Editar Cohorte</h3>
            </div>
            <div class='card-body'>
               {{ include('cohorte/_form.html.twig', {'button_label': 'Guardar'}) }}
            </div>
        </div>
        

   </div>

{% endblock %}

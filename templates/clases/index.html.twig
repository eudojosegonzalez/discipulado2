{% extends 'base.html.twig' %}

{% block title %}Lecciones - Maranatha Discipulado{% endblock %}

{% block body %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <button type="button" id="sidebarCollapse" class="btn btn-dark mr-2">
            <i class="fas fa-bars"></i>
        </button>
        <a class="navbar-brand" href="#">
           <img src="{{ appLogo }}" alt="Logo" style="height:45px !important">
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>        
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-user-circle mr-1"></i> Perfil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-cog mr-1"></i> Configuración</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/logout"><i class="fas fa-sign-out-alt mr-1"></i> Salir</a>
                </li>
            </ul>
        </div>
    </nav>
    <!-- Sidebar -->
    {% include 'navigation_admin.html.twig' %}
    <!-- Contenido Principal -->
    <div id="content" style=" padding:5px !important">    
        <p>&nbsp;</p>
        <h1>Lecciones en el Sistema</h1>
        <p>&nbsp;</p>
        <div class="my-3 text-center"> {# Un div para agrupar y dar un poco de margen #}
            <a href="{{ path('app_clases_new') }}" title='Agregar una lección nueva al sistema' class="btn btn-primary btn-lg rounded-lg">
                <i class="fa fa-plus-square" style='font-size: 24px;'></i> {# Ajusté el tamaño para que se vea mejor en un botón #}
                Agregar Leccion
            </a>
        </div>         
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Titulo</th>
                    <th>Módulo</th>
                    <th>Orden</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tbody>
            {% set i = 1 %}
            {% for clase in clases %}
                <tr>
                    <td class='text-center'>{{ i }}</td>
                    <td>{{ clase.titulo }}</td>
                    <td>{{ clase.modulo.nombre }}</td>
                    <td class='text-center'>{{ clase.orden }}</td>
                    <td class='text-center'>
                        <a href="{{ path('app_clases_show', {'id': clase.id}) }}"><i class="fa-solid fa-eye"></i></a>
                        <a href="{{ path('app_clases_edit', {'id': clase.id}) }}"><i class="fa-solid fa-user-pen"></i></a>
                    </td>
                </tr>
                {% set i = i + 1 %}
            {% else %}
                <tr>
                    <td colspan="5" class="text-danger">No hay lecciones definidas en el sistema</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <script>
        $(document).ready(function() {
            // Colapsar/Expandir Sidebar
            $('#sidebarCollapse').on('click', function() {
                $('#sidebar').toggleClass('active');
                $('#content').toggleClass('active');
            });
            
            // Hacer que los items del sidebar sean activos al hacer clic
            $('.sidebar-item').on('click', function() {
                $('.sidebar-item').removeClass('active');
                $(this).addClass('active');
            });
        });        
    </script>
{% endblock %}
